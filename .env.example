# ============================================================
# Amazon Affiliate Bot — Environment Variables
# Copy this file to ".env" and fill in your values
# ============================================================

# REQUIRED ---------------------------------------------------

# Your Telegram bot token from @BotFather (see README)
TELEGRAM_BOT_TOKEN=

# Your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=

# Your Amazon Affiliate tag (e.g. yourname-21 for amazon.in)
AMAZON_AFFILIATE_TAG=

# OPTIONAL ---------------------------------------------------

# Amazon marketplace: IN, US, UK, DE, CA, AU, JP
AMAZON_COUNTRY=IN

# Amazon PA-API credentials (only after Associates approval — needs 3 sales first)
# Leave blank to use search-URL fallback mode (works immediately, no setup)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
